APP_ENV=production
APP_HOST=0.0.0.0
APP_PORT=8080
FRONTEND_PORT=8081
APP_IMAGE=docker.io/lightjunction/lab-safety-system:latest
BACKEND_IMAGE=docker.io/lightjunction/lab-safety-system-backend:latest
FRONTEND_IMAGE=docker.io/lightjunction/lab-safety-system-frontend:latest

POSTGRES_DB=lab_safety
POSTGRES_USER=lab_safety
POSTGRES_PASSWORD=ReplaceWith_StrongPgPassword_2026!
POSTGRES_PORT=5432
DATABASE_URL=postgresql://lab_safety:ReplaceWith_StrongPgPassword_2026!@postgres:5432/lab_safety
# Production startup rejects placeholder or short secrets.
SECRET_KEY=ReplaceWith_AtLeast32RandomChars_2026!
TOKEN_TTL_SECONDS=3600
UPLOAD_DIR=/app/uploads
# Integrated deployment serves the built frontend from this directory.
# Leave empty for separated frontend/backend deployment.
STATIC_DIR=/app/public

SSO_ENABLED=false
OAUTH_ENABLED=false
SSO_LOGIN_URL=
OAUTH_LOGIN_URL=
FEDERATED_LOGIN_SECRET=
WEBAUTHN_RP_ID=localhost
# Integrated deployment default. For separated frontend deployment, use http://localhost:8081.
WEBAUTHN_ORIGIN=http://localhost:8080
# Comma-separated extra browser origins allowed to call the API in production.
CORS_ALLOWED_ORIGINS=
