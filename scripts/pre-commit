#!/bin/bash
# Local Git Pre-Commit Hook for Lab Safety System
# Ensures code quality before allowing commit.

# Color definitions
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
NC='\033[0m' # No Color

echo -e "${YELLOW}=== Running pre-commit verification ===${NC}"

# Track if any check failed
FAILED=0

# 1. Check Rust formatting
echo -e "${YELLOW}[1/3] Checking Rust code formatting...${NC}"
if ! cargo fmt --all -- --check; then
    echo -e "${RED}✘ Rust formatting check failed. Please run 'cargo fmt --all' to fix.${NC}"
    FAILED=1
else
    echo -e "${GREEN}✔ Rust formatting is correct.${NC}"
fi

# 2. Run Cargo Clippy for static analysis
echo -e "${YELLOW}[2/3] Running Cargo Clippy...${NC}"
if ! cargo clippy --all-targets -- -D warnings; then
    echo -e "${RED}✘ Clippy checks failed. Please fix the compiler warnings.${NC}"
    FAILED=1
else
    echo -e "${GREEN}✔ Clippy passed successfully.${NC}"
fi

# 3. Check Frontend status (only if frontend files changed)
# Check if there are staged changes in the frontend folder
FRONTEND_CHANGED=$(git diff --cached --name-only | grep -E '^frontend/')

if [ -n "$FRONTEND_CHANGED" ]; then
    echo -e "${YELLOW}[3/3] Frontend changes detected. Running build check...${NC}"
    cd frontend
    # Check if node_modules is installed
    if [ ! -d "node_modules" ]; then
        echo -e "${YELLOW}node_modules not found. Installing dependencies...${NC}"
        npm install
    fi
    if ! npm run build; then
        echo -e "${RED}✘ Frontend build check failed. Please verify TypeScript types or Vite configuration.${NC}"
        FAILED=1
    else
        echo -e "${GREEN}✔ Frontend build check passed.${NC}"
    fi
    cd ..
else
    echo -e "${GREEN}[3/3] No frontend changes detected. Skipping frontend check.${NC}"
fi

echo ""
if [ $FAILED -ne 0 ]; then
    echo -e "${RED}❌ Commit aborted. Please resolve the errors above and try again.${NC}"
    exit 1
else
    echo -e "${GREEN}✨ Verification successful! Code is clean. Committing...${NC}"
    exit 0
fi
